{
    "id": "com.makineceviri.live",
    "name": "MakineAI OCR",
    "version": "0.1.0",
    "apiVersion": 1,
    "category": "translation",
    "description": "Real-time screen OCR and translation overlay with DXGI capture and multi-engine translation",
    "author": "MakineAI Team",
    "license": "GPL-3.0",
    "homepage": "https://github.com/MakineCeviri/makineai-plugin-live",
    "entry": "makineai-live.dll",
    "dependencies": [],
    "capabilities": ["network", "screen_capture", "overlay"],
    "features": [
        "Screen capture (DXGI Desktop Duplication / GDI fallback)",
        "OCR text recognition (RapidOCR)",
        "Translation engines (Google, DeepL, ChatGPT)",
        "Transparent overlay window",
        "Frame change detection for efficient OCR"
    ],
    "platforms": ["win64"],
    "minLauncherVersion": "0.2.0",
    "settings": [
        {
            "key": "ocrEnabled",
            "type": "toggle",
            "label": "OCR Aktif",
            "default": "false"
        },
        {
            "key": "sourceLang",
            "type": "select",
            "label": "Kaynak Dil",
            "options": ["en", "ja", "ko", "zh", "de", "fr", "es", "ru"],
            "default": "en"
        },
        {
            "key": "targetLang",
            "type": "select",
            "label": "Hedef Dil",
            "options": ["tr", "en", "de", "fr", "es", "ru"],
            "default": "tr"
        },
        {
            "key": "translatorEngine",
            "type": "select",
            "label": "Ceviri Motoru",
            "options": ["gpt", "deepl", "google"],
            "default": "gpt"
        },
        {
            "key": "apiKey",
            "type": "text",
            "label": "API Anahtari",
            "default": ""
        },
        {
            "key": "gptModel",
            "type": "select",
            "label": "GPT Model",
            "options": ["gpt-4o-mini", "gpt-4o", "gpt-4-turbo"],
            "default": "gpt-4o-mini"
        },
        {
            "key": "captureMethod",
            "type": "select",
            "label": "Yakalama Yontemi",
            "options": ["auto", "dxgi", "gdi"],
            "default": "auto"
        },
        {
            "key": "ocrInterval",
            "type": "select",
            "label": "OCR Araligi (ms)",
            "options": ["500", "1000", "2000", "3000", "5000"],
            "default": "2000"
        }
    ]
}
